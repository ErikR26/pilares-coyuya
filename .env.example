# ─────────────────────────────────────────────────────────────────────────────
# PILARES COYUYA — Variables de Entorno
#
# INSTRUCCIONES:
#   1. Copia este archivo → cp .env.example .env.local
#   2. Reemplaza cada valor con tus credenciales reales de Supabase.
#   3. NUNCA subas ".env.local" a GitHub — está protegido en .gitignore.
#   4. En Vercel: Settings → Environment Variables → agrega las mismas.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (frontend — visibles en el navegador) ────────────────────────────
# Encuéntralos en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase DB — solo para el script init-db.js (NUNCA exponer al navegador) ─
# Encuéntala en: Settings → Database → Connection string → URI
# Formato: postgresql://postgres:[TU-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:[TU-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres
