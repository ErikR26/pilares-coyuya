# ─────────────────────────────────────────────────────────────────────────────
# PILARES COYUYA — Variables de Entorno
#
# INSTRUCCIONES:
#   1. Copia este archivo y renómbralo como ".env.local"  →  cp .env.example .env.local
#   2. Reemplaza cada valor de ejemplo con tus credenciales reales.
#   3. NUNCA subas ".env.local" a GitHub. Ya está protegido en el .gitignore.
#   4. En Vercel: agrega estas mismas variables en:
#        Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Encuéntralos en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=tu_url_de_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_anonima_de_supabase
